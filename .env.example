# Sessão
SESSION_SECRET=troque_por_uma_chave_grande_e_unica

# GitHub persistence
GITHUB_TOKEN=cole_seu_token_aqui
GITHUB_REPO=stepmanus-boop/Step-Gerencia
GITHUB_BRANCH=main

# Smartsheet API
SMARTSHEET_TOKEN=cole_seu_token_real
SMARTSHEET_SHEET_NAME=nome_da_sheet
# SMARTSHEET_SHEET_ID=id_da_sheet

# Opcional: caminho local temporário para deploys sem GitHub
LOCAL_DATA_ROOT=/tmp/step-gerencia-data

# Web Push (alertas manuais no celular)
VAPID_PUBLIC_KEY=COLE_AQUI_A_CHAVE_PUBLICA_VAPID
VAPID_PRIVATE_KEY=COLE_AQUI_A_CHAVE_PRIVADA_VAPID
VAPID_SUBJECT=mailto:seu-email@dominio.com
